{
  "name": "octoactions",
  "version": "1.0.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "submit": "wxt submit --chrome-zip .output/octoactions-$npm_package_version-chrome.zip",
    "submit:init": "publish-extension init",
    "release": "npm run zip && npm run submit",
    "format": "oxfmt ."
  },
  "dependencies": {
    "typescript": "^6.0.2",
    "wxt": "^0.20.20"
  },
  "devDependencies": {
    "oxfmt": "^0.43.0"
  }
}
