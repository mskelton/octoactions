# Copy this file to `.env.submit` and fill in the values.
# See PUBLISHING.md for how to generate each credential.

CHROME_EXTENSION_ID=
CHROME_CLIENT_ID=
CHROME_CLIENT_SECRET=
CHROME_REFRESH_TOKEN=

# Optional: where the extension is published (default=default).
# Use "trustedTesters" to push to the trusted testers channel instead of public.
# CHROME_PUBLISH_TARGET=default

# Optional: skip verification for faster submits. Only set once you've verified
# the submit flow works end-to-end.
# CHROME_SKIP_SUBMIT_REVIEW=false
